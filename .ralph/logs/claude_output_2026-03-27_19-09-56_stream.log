{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012faMVxtiQyTBZ6Rvqqmnhk","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useState, useEffect } from \"react\";\n     4→import { signUp, signIn, signOut, getCurrentUser, type SyncUser } from \"@/lib/sync\";\n     5→\n     6→type Mode = \"idle\" | \"signup\" | \"signin\";\n     7→\n     8→export default function AccountSync() {\n     9→  const [user, setUser] = useState<SyncUser | null>(null);\n    10→  const [mode, setMode] = useState<Mode>(\"idle\");\n    11→  const [email, setEmail] = useState(\"\");\n    12→  const [password, setPassword] = useState(\"\");\n    13→  const [error, setError] = useState<string | null>(null);\n    14→  const [loading, setLoading] = useState(false);\n    15→  const [success, setSuccess] = useState(false);\n    16→  const [mounted, setMounted] = useState(false);\n    17→\n    18→  useEffect(() => {\n    19→    setMounted(true);\n    20→    getCurrentUser().then(setUser);\n    21→  }, []);\n    22→\n    23→  if (!mounted) return null;\n    24→\n    25→  async function handleSubmit(e: React.FormEvent) {\n    26→    e.preventDefault();\n    27→    setError(null);\n    28→    setLoading(true);\n    29→\n    30→    const result = mode === \"signup\"\n    31→      ? await signUp(email, password)\n    32→      : await signIn(email, password);\n    33→\n    34→    setLoading(false);\n    35→\n    36→    if (result.error) {\n    37→      setError(result.error);\n    38→    } else {\n    39→      setSuccess(true);\n    40→      const u = await getCurrentUser();\n    41→      setUser(u);\n    42→      setMode(\"idle\");\n    43→      setTimeout(() => setSuccess(false), 4000);\n    44→    }\n    45→  }\n    46→\n    47→  async function handleSignOut() {\n    48→    await signOut();\n    49→    setUser(null);\n    50→  }\n    51→\n    52→  // Signed in — show account info\n    53→  if (user) {\n    54→    return (\n    55→      <div className=\"bg-white border border-gray-200 rounded-xl p-4 flex items-center justify-between\">\n    56→        <div>\n    57→          <p className=\"text-sm font-semibold text-gray-700\">✓ Progress synced</p>\n    58→          <p className=\"text-xs text-gray-400\">{user.email}</p>\n    59→        </div>\n    60→        <button\n    61→          onClick={handleSignOut}\n    62→          className=\"text-xs text-gray-400 hover:text-gray-700 transition-colors\"\n    63→        >\n    64→          Sign out\n    65→        </button>\n    66→      </div>\n    67→    );\n    68→  }\n    69→\n    70→  // Success flash\n    71→  if (success) {\n    72→    return (\n    73→      <div className=\"bg-green-50 border border-green-200 rounded-xl p-4 text-center\">\n    74→        <p className=\"text-sm font-semibold text-green-700\">\n    75→          {mode === \"signup\" ? \"✓ Account created! Progress saved.\" : \"✓ Signed in! Progress synced.\"}\n    76→        </p>\n    77→      </div>\n    78→    );\n    79→  }\n    80→\n    81→  // Form mode\n    82→  if (mode !== \"idle\") {\n    83→    return (\n    84→      <div className=\"bg-white border border-gray-200 rounded-xl p-5\">\n    85→        <div className=\"flex items-center justify-between mb-4\">\n    86→          <h3 className=\"font-semibold text-gray-900 text-sm\">\n    87→            {mode === \"signup\" ? \"Save progress across devices\" : \"Sign in to your account\"}\n    88→          </h3>\n    89→          <button\n    90→            onClick={() => { setMode(\"idle\"); setError(null); }}\n    91→            className=\"text-gray-400 hover:text-gray-700 text-lg leading-none\"\n    92→          >\n    93→            ×\n    94→          </button>\n    95→        </div>\n    96→        <form onSubmit={handleSubmit} className=\"space-y-3\">\n    97→          <input\n    98→            type=\"email\"\n    99→            placeholder=\"Email\"\n   100→            value={email}\n   101→            onChange={(e) => setEmail(e.target.value)}\n   102→            required\n   103→            className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500\"\n   104→          />\n   105→          <input\n   106→            type=\"password\"\n   107→            placeholder=\"Password\"\n   108→            value={password}\n   109→            onChange={(e) => setPassword(e.target.value)}\n   110→            required\n   111→            minLength={6}\n   112→            className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500\"\n   113→          />\n   114→          {error && <p className=\"text-xs text-red-500\">{error}</p>}\n   115→          <button\n   116→            type=\"submit\"\n   117→            disabled={loading}\n   118→            className=\"w-full bg-brand-600 text-white font-medium py-2 rounded-lg text-sm hover:bg-brand-700 disabled:opacity-50 transition-colors\"\n   119→          >\n   120→            {loading ? \"...\" : mode === \"signup\" ? \"Create Account\" : \"Sign In\"}\n   121→          </button>\n   122→        </form>\n   123→        <button\n   124→          onClick={() => setMode(mode === \"signup\" ? \"signin\" : \"signup\")}\n   125→          className=\"text-xs text-gray-400 hover:text-brand-600 mt-3 w-full text-center transition-colors\"\n   126→        >\n   127→          {mode === \"signup\" ? \"Already have an account? Sign in\" : \"No account? Create one free\"}\n   128→        </button>\n   129→      </div>\n   130→    );\n   131→  }\n   132→\n   133→  // Default — invite to sync (non-intrusive)\n   134→  return (\n   135→    <div className=\"bg-gray-50 border border-dashed border-gray-200 rounded-xl p-4 text-center\">\n   136→      <p className=\"text-sm text-gray-500 mb-3\">\n   137→        Want your progress on all devices?\n   138→      </p>\n   139→      <div className=\"flex gap-2 justify-center\">\n   140→        <button\n   141→          onClick={() => setMode(\"signup\")}\n   142→          className=\"text-xs bg-brand-600 text-white font-medium px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors\"\n   143→        >\n   144→          Save Progress\n   145→        </button>\n   146→        <button\n   147→          onClick={() => setMode(\"signin\")}\n   148→          className=\"text-xs border border-gray-200 text-gray-500 font-medium px-4 py-2 rounded-lg hover:border-gray-300 transition-colors\"\n   149→        >\n   150→          Sign In\n   151→        </button>\n   152→      </div>\n   153→    </div>\n   154→  );\n   155→}\n   156→"}]},"parent_tool_use_id":null,"session_id":"f35b7b4d-e00d-4a46-b7f3-fc8a38b8e426","uuid":"a876d3a8-9eeb-4bc2-b334-7a9600a64c9f","timestamp":"2026-03-28T00:13:04.822Z","tool_use_result":{"type":"text","file":{"filePath":"/root/clawd/epiphany-learn/components/auth/AccountSync.tsx","content":"\"use client\";\n\nimport { useState, useEffect } from \"react\";\nimport { signUp, signIn, signOut, getCurrentUser, type SyncUser } from \"@/lib/sync\";\n\ntype Mode = \"idle\" | \"signup\" | \"signin\";\n\nexport default function AccountSync() {\n  const [user, setUser] = useState<SyncUser | null>(null);\n  const [mode, setMode] = useState<Mode>(\"idle\");\n  const [email, setEmail] = useState(\"\");\n  const [password, setPassword] = useState(\"\");\n  const [error, setError] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [success, setSuccess] = useState(false);\n  const [mounted, setMounted] = useState(false);\n\n  useEffect(() => {\n    setMounted(true);\n    getCurrentUser().then(setUser);\n  }, []);\n\n  if (!mounted) return null;\n\n  async function handleSubmit(e: React.FormEvent) {\n    e.preventDefault();\n    setError(null);\n    setLoading(true);\n\n    const result = mode === \"signup\"\n      ? await signUp(email, password)\n      : await signIn(email, password);\n\n    setLoading(false);\n\n    if (result.error) {\n      setError(result.error);\n    } else {\n      setSuccess(true);\n      const u = await getCurrentUser();\n      setUser(u);\n      setMode(\"idle\");\n      setTimeout(() => setSuccess(false), 4000);\n    }\n  }\n\n  async function handleSignOut() {\n    await signOut();\n    setUser(null);\n  }\n\n  // Signed in — show account info\n  if (user) {\n    return (\n      <div className=\"bg-white border border-gray-200 rounded-xl p-4 flex items-center justify-between\">\n        <div>\n          <p className=\"text-sm font-semibold text-gray-700\">✓ Progress synced</p>\n          <p className=\"text-xs text-gray-400\">{user.email}</p>\n        </div>\n        <button\n          onClick={handleSignOut}\n          className=\"text-xs text-gray-400 hover:text-gray-700 transition-colors\"\n        >\n          Sign out\n        </button>\n      </div>\n    );\n  }\n\n  // Success flash\n  if (success) {\n    return (\n      <div className=\"bg-green-50 border border-green-200 rounded-xl p-4 text-center\">\n        <p className=\"text-sm font-semibold text-green-700\">\n          {mode === \"signup\" ? \"✓ Account created! Progress saved.\" : \"✓ Signed in! Progress synced.\"}\n        </p>\n      </div>\n    );\n  }\n\n  // Form mode\n  if (mode !== \"idle\") {\n    return (\n      <div className=\"bg-white border border-gray-200 rounded-xl p-5\">\n        <div className=\"flex items-center justify-between mb-4\">\n          <h3 className=\"font-semibold text-gray-900 text-sm\">\n            {mode === \"signup\" ? \"Save progress across devices\" : \"Sign in to your account\"}\n          </h3>\n          <button\n            onClick={() => { setMode(\"idle\"); setError(null); }}\n            className=\"text-gray-400 hover:text-gray-700 text-lg leading-none\"\n          >\n            ×\n          </button>\n        </div>\n        <form onSubmit={handleSubmit} className=\"space-y-3\">\n          <input\n            type=\"email\"\n            placeholder=\"Email\"\n            value={email}\n            onChange={(e) => setEmail(e.target.value)}\n            required\n            className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500\"\n          />\n          <input\n            type=\"password\"\n            placeholder=\"Password\"\n            value={password}\n            onChange={(e) => setPassword(e.target.value)}\n            required\n            minLength={6}\n            className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500\"\n          />\n          {error && <p className=\"text-xs text-red-500\">{error}</p>}\n          <button\n            type=\"submit\"\n            disabled={loading}\n            className=\"w-full bg-brand-600 text-white font-medium py-2 rounded-lg text-sm hover:bg-brand-700 disabled:opacity-50 transition-colors\"\n          >\n            {loading ? \"...\" : mode === \"signup\" ? \"Create Account\" : \"Sign In\"}\n          </button>\n        </form>\n        <button\n          onClick={() => setMode(mode === \"signup\" ? \"signin\" : \"signup\")}\n          className=\"text-xs text-gray-400 hover:text-brand-600 mt-3 w-full text-center transition-colors\"\n        >\n          {mode === \"signup\" ? \"Already have an account? Sign in\" : \"No account? Create one free\"}\n        </button>\n      </div>\n    );\n  }\n\n  // Default — invite to sync (non-intrusive)\n  return (\n    <div className=\"bg-gray-50 border border-dashed border-gray-200 rounded-xl p-4 text-center\">\n      <p className=\"text-sm text-gray-500 mb-3\">\n        Want your progress on all devices?\n      </p>\n      <div className=\"flex gap-2 justify-center\">\n        <button\n          onClick={() => setMode(\"signup\")}\n          className=\"text-xs bg-brand-600 text-white font-medium px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors\"\n        >\n          Save Progress\n        </button>\n        <button\n          onClick={() => setMode(\"signin\")}\n          className=\"text-xs border border-gray-200 text-gray-500 font-medium px-4 py-2 rounded-lg hover:border-gray-300 transition-colors\"\n        >\n          Sign In\n        </button>\n      </div>\n    </div>\n  );\n}\n","numLines":156,"startLine":1,"totalLines":156}}}
