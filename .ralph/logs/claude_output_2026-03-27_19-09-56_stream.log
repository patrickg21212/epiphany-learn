{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q8M8egw7AoF7qMnExfY8us","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import Image from \"next/image\";\n     4→import { useEffect, useState } from \"react\";\n     5→import { motion, AnimatePresence } from \"framer-motion\";\n     6→import type { Badge } from \"@/lib/achievements\";\n     7→\n     8→interface Props {\n     9→  badge: Badge;\n    10→  onDismiss?: () => void;\n    11→  autoDismissMs?: number;\n    12→}\n    13→\n    14→export default function BadgeToast({ badge, onDismiss, autoDismissMs = 5000 }: Props) {\n    15→  const [progress, setProgress] = useState(100);\n    16→  const [visible, setVisible] = useState(true);\n    17→\n    18→  useEffect(() => {\n    19→    const start = Date.now();\n    20→    const interval = setInterval(() => {\n    21→      const elapsed = Date.now() - start;\n    22→      const remaining = Math.max(0, 100 - (elapsed / autoDismissMs) * 100);\n    23→      setProgress(remaining);\n    24→      if (remaining === 0) {\n    25→        clearInterval(interval);\n    26→        setVisible(false);\n    27→        setTimeout(() => onDismiss?.(), 300);\n    28→      }\n    29→    }, 50);\n    30→    return () => clearInterval(interval);\n    31→  }, [autoDismissMs, onDismiss]);\n    32→\n    33→  return (\n    34→    <AnimatePresence>\n    35→      {visible && (\n    36→        <motion.div\n    37→          initial={{ x: 120, opacity: 0, scale: 0.8 }}\n    38→          animate={{ x: 0, opacity: 1, scale: 1 }}\n    39→          exit={{ x: 120, opacity: 0, scale: 0.8 }}\n    40→          transition={{ type: \"spring\", stiffness: 400, damping: 30 }}\n    41→          className=\"fixed bottom-6 right-6 z-50 bg-white shadow-2xl rounded-2xl p-5 max-w-xs border border-brand-200 overflow-hidden\"\n    42→        >\n    43→          {/* Glow ring behind badge */}\n    44→          <div className=\"flex items-start gap-3\">\n    45→            <div className=\"flex-shrink-0 w-14 h-14 relative\">\n    46→              <motion.div\n    47→                className=\"absolute inset-0 rounded-full bg-brand-400 opacity-0\"\n    48→                animate={{ scale: [1, 1.4, 1], opacity: [0, 0.3, 0] }}\n    49→                transition={{ repeat: 2, duration: 0.8 }}\n    50→              />\n    51→              <motion.div\n    52→                initial={{ scale: 0, rotate: -20 }}\n    53→                animate={{ scale: 1, rotate: 0 }}\n    54→                transition={{ type: \"spring\", stiffness: 500, damping: 20, delay: 0.1 }}\n    55→                className=\"w-14 h-14 flex items-center justify-center\"\n    56→              >\n    57→                {badge.svgPath ? (\n    58→                  <Image src={badge.svgPath} alt={badge.title} width={56} height={56} />\n    59→                ) : (\n    60→                  <span className=\"text-4xl\">{badge.icon}</span>\n    61→                )}\n    62→              </motion.div>\n    63→            </div>\n    64→\n    65→            <div>\n    66→              <motion.p\n    67→                initial={{ opacity: 0, y: 4 }}\n    68→                animate={{ opacity: 1, y: 0 }}\n    69→                transition={{ delay: 0.2 }}\n    70→                className=\"text-xs text-brand-500 font-semibold uppercase tracking-wide mb-1\"\n    71→              >\n    72→                🏆 Badge Unlocked!\n    73→              </motion.p>\n    74→              <motion.h3\n    75→                initial={{ opacity: 0, y: 4 }}\n    76→                animate={{ opacity: 1, y: 0 }}\n    77→                transition={{ delay: 0.25 }}\n    78→                className=\"font-bold text-gray-900\"\n    79→              >\n    80→                {badge.title}\n    81→              </motion.h3>\n    82→              <motion.p\n    83→                initial={{ opacity: 0, y: 4 }}\n    84→                animate={{ opacity: 1, y: 0 }}\n    85→                transition={{ delay: 0.3 }}\n    86→                className=\"text-sm text-gray-500 mt-0.5\"\n    87→              >\n    88→                {badge.description}\n    89→              </motion.p>\n    90→              <motion.p\n    91→                initial={{ opacity: 0 }}\n    92→                animate={{ opacity: 1 }}\n    93→                transition={{ delay: 0.35 }}\n    94→                className=\"text-xs text-brand-600 font-medium mt-1\"\n    95→              >\n    96→                +{badge.xpReward} XP\n    97→              </motion.p>\n    98→            </div>\n    99→          </div>\n   100→\n   101→          {/* Dismiss button */}\n   102→          {onDismiss && (\n   103→            <button\n   104→              onClick={() => { setVisible(false); setTimeout(() => onDismiss(), 300); }}\n   105→              className=\"absolute top-3 right-3 text-gray-400 hover:text-gray-600 transition-colors\"\n   106→            >\n   107→              ✕\n   108→            </button>\n   109→          )}\n   110→\n   111→          {/* Auto-dismiss progress bar */}\n   112→          <div className=\"absolute bottom-0 left-0 right-0 h-1 bg-gray-100\">\n   113→            <motion.div\n   114→              className=\"h-full bg-brand-400 rounded-b-2xl\"\n   115→              style={{ width: `${progress}%` }}\n   116→              transition={{ ease: \"linear\" }}\n   117→            />\n   118→          </div>\n   119→        </motion.div>\n   120→      )}\n   121→    </AnimatePresence>\n   122→  );\n   123→}\n   124→"}]},"parent_tool_use_id":null,"session_id":"f35b7b4d-e00d-4a46-b7f3-fc8a38b8e426","uuid":"5b000bdc-ebd1-4ae2-88f7-426319d37593","timestamp":"2026-03-28T00:10:47.827Z","tool_use_result":{"type":"text","file":{"filePath":"/root/clawd/epiphany-learn/components/gamification/BadgeToast.tsx","content":"\"use client\";\n\nimport Image from \"next/image\";\nimport { useEffect, useState } from \"react\";\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport type { Badge } from \"@/lib/achievements\";\n\ninterface Props {\n  badge: Badge;\n  onDismiss?: () => void;\n  autoDismissMs?: number;\n}\n\nexport default function BadgeToast({ badge, onDismiss, autoDismissMs = 5000 }: Props) {\n  const [progress, setProgress] = useState(100);\n  const [visible, setVisible] = useState(true);\n\n  useEffect(() => {\n    const start = Date.now();\n    const interval = setInterval(() => {\n      const elapsed = Date.now() - start;\n      const remaining = Math.max(0, 100 - (elapsed / autoDismissMs) * 100);\n      setProgress(remaining);\n      if (remaining === 0) {\n        clearInterval(interval);\n        setVisible(false);\n        setTimeout(() => onDismiss?.(), 300);\n      }\n    }, 50);\n    return () => clearInterval(interval);\n  }, [autoDismissMs, onDismiss]);\n\n  return (\n    <AnimatePresence>\n      {visible && (\n        <motion.div\n          initial={{ x: 120, opacity: 0, scale: 0.8 }}\n          animate={{ x: 0, opacity: 1, scale: 1 }}\n          exit={{ x: 120, opacity: 0, scale: 0.8 }}\n          transition={{ type: \"spring\", stiffness: 400, damping: 30 }}\n          className=\"fixed bottom-6 right-6 z-50 bg-white shadow-2xl rounded-2xl p-5 max-w-xs border border-brand-200 overflow-hidden\"\n        >\n          {/* Glow ring behind badge */}\n          <div className=\"flex items-start gap-3\">\n            <div className=\"flex-shrink-0 w-14 h-14 relative\">\n              <motion.div\n                className=\"absolute inset-0 rounded-full bg-brand-400 opacity-0\"\n                animate={{ scale: [1, 1.4, 1], opacity: [0, 0.3, 0] }}\n                transition={{ repeat: 2, duration: 0.8 }}\n              />\n              <motion.div\n                initial={{ scale: 0, rotate: -20 }}\n                animate={{ scale: 1, rotate: 0 }}\n                transition={{ type: \"spring\", stiffness: 500, damping: 20, delay: 0.1 }}\n                className=\"w-14 h-14 flex items-center justify-center\"\n              >\n                {badge.svgPath ? (\n                  <Image src={badge.svgPath} alt={badge.title} width={56} height={56} />\n                ) : (\n                  <span className=\"text-4xl\">{badge.icon}</span>\n                )}\n              </motion.div>\n            </div>\n\n            <div>\n              <motion.p\n                initial={{ opacity: 0, y: 4 }}\n                animate={{ opacity: 1, y: 0 }}\n                transition={{ delay: 0.2 }}\n                className=\"text-xs text-brand-500 font-semibold uppercase tracking-wide mb-1\"\n              >\n                🏆 Badge Unlocked!\n              </motion.p>\n              <motion.h3\n                initial={{ opacity: 0, y: 4 }}\n                animate={{ opacity: 1, y: 0 }}\n                transition={{ delay: 0.25 }}\n                className=\"font-bold text-gray-900\"\n              >\n                {badge.title}\n              </motion.h3>\n              <motion.p\n                initial={{ opacity: 0, y: 4 }}\n                animate={{ opacity: 1, y: 0 }}\n                transition={{ delay: 0.3 }}\n                className=\"text-sm text-gray-500 mt-0.5\"\n              >\n                {badge.description}\n              </motion.p>\n              <motion.p\n                initial={{ opacity: 0 }}\n                animate={{ opacity: 1 }}\n                transition={{ delay: 0.35 }}\n                className=\"text-xs text-brand-600 font-medium mt-1\"\n              >\n                +{badge.xpReward} XP\n              </motion.p>\n            </div>\n          </div>\n\n          {/* Dismiss button */}\n          {onDismiss && (\n            <button\n              onClick={() => { setVisible(false); setTimeout(() => onDismiss(), 300); }}\n              className=\"absolute top-3 right-3 text-gray-400 hover:text-gray-600 transition-colors\"\n            >\n              ✕\n            </button>\n          )}\n\n          {/* Auto-dismiss progress bar */}\n          <div className=\"absolute bottom-0 left-0 right-0 h-1 bg-gray-100\">\n            <motion.div\n              className=\"h-full bg-brand-400 rounded-b-2xl\"\n              style={{ width: `${progress}%` }}\n              transition={{ ease: \"linear\" }}\n            />\n          </div>\n        </motion.div>\n      )}\n    </AnimatePresence>\n  );\n}\n","numLines":124,"startLine":1,"totalLines":124}}}
