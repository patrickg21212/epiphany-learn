n","           </button>"]}],"originalFile":"\"use client\";\n\nimport { useState, useMemo } from \"react\";\n\ninterface Pair {\n  term: string;\n  definition: string;\n}\n\ninterface Props {\n  id?: string;\n  instruction?: string;\n  pairs: Pair[];\n}\n\nfunction shuffle<T>(arr: T[]): T[] {\n  return [...arr].sort(() => Math.random() - 0.5);\n}\n\nexport default function MatchTerms({ instruction, pairs }: Props) {\n  const shuffledDefs = useMemo(() => shuffle(pairs.map((p) => p.definition)), [pairs]);\n  const [matches, setMatches] = useState<Record<string, string>>({});\n  const [selectedTerm, setSelectedTerm] = useState<string | null>(null);\n  const [submitted, setSubmitted] = useState(false);\n\n  const score = submitted\n    ? pairs.filter((p) => matches[p.term] === p.definition).length\n    : 0;\n\n  function handleTermClick(term: string) {\n    if (submitted) return;\n    setSelectedTerm((prev) => (prev === term ? null : term));\n  }\n\n  function handleDefClick(def: string) {\n    if (submitted || !selectedTerm) return;\n    setMatches((prev) => ({ ...prev, [selectedTerm]: def }));\n    setSelectedTerm(null);\n  }\n\n  const allMatched = pairs.every((p) => matches[p.term]);\n  const matchedDefs = new Set(Object.values(matches));\n\n  function handleSubmit() {\n    if (!allMatched) return;\n    setSubmitted(true);\n  }\n\n  function handleRetry() {\n    setMatches({});\n    setSelectedTerm(null);\n    setSubmitted(false);\n  }\n\n  return (\n    <div className=\"my-6 rounded-2xl border border-gray-200 bg-white overflow-hidden\">\n      <div className=\"bg-brand-600 px-5 py-3 flex items-center justify-between\">\n        <span className=\"text-white font-semibold text-sm\">Match the Terms</span>\n        {submitted && (\n          <span className=\"text-white/90 text-sm font-medium\">\n            {score}/{pairs.length} correct\n          </span>\n        )}\n      </div>\n\n      <div className=\"p-5\">\n        {instruction && (\n          <p className=\"text-sm text-gray-600 mb-4\">{instruction}</p>\n        )}\n\n        {!submitted && (\n          <p className=\"text-xs text-gray-400 mb-3\">\n            {selectedTerm ? `Select a definition for \"${selectedTerm}\"` : \"Click a term, then click its matching definition.\"}\n          </p>\n        )}\n\n        <div className=\"grid grid-cols-2 gap-3\">\n          {/* Terms column */}\n          <div className=\"space-y-2\">\n            <p className=\"text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1\">Terms</p>\n            {pairs.map((p) => {\n              const isSelected = selectedTerm === p.term;\n              const isMatched = !!matches[p.term];\n              const isCorrect = submitted && matches[p.term] === p.definition;\n              const isWrong = submitted && matches[p.term] !== p.definition;\n\n              return (\n                <button\n                  key={p.term}\n                  onClick={() => handleTermClick(p.term)}\n                  disabled={submitted}\n                  className={`w-full text-left px-3 py-2.5 rounded-lg border-2 text-sm font-medium transition-all ${\n                    submitted\n                      ? isCorrect\n                        ? \"border-green-400 bg-green-50 text-green-800\"\n                        : isWrong\n                        ? \"border-red-300 bg-red-50 text-red-700\"\n                        : \"border-gray-200 text-gray-400\"\n                      : isSelected\n                      ? \"border-brand-500 bg-brand-50 text-brand-800\"\n                      : isMatched\n                      ? \"border-brand-200 bg-brand-50/50 text-gray-700\"\n                      : \"border-gray-200 text-gray-700 hover:border-brand-300 hover:bg-gray-50\"\n                  }`}\n                >\n                  {p.term}\n                  {isMatched && !submitted && <span className=\"ml-1 text-xs text-brand-400\">✓</span>}\n                  {submitted && isCorrect && <span className=\"ml-1 text-green-500\">✓</span>}\n                </button>\n              );\n            })}\n          </div>\n\n          {/* Definitions column */}\n          <div className=\"space-y-2\">\n            <p className=\"text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1\">Definitions</p>\n            {shuffledDefs.map((def) => {\n              const isUsed = matchedDefs.has(def);\n              const isClickable = !!selectedTerm && !isUsed;\n              const matchedTerm = Object.entries(matches).find(([, d]) => d === def)?.[0];\n              const isCorrect = submitted && matchedTerm && pairs.find((p) => p.term === matchedTerm)?.definition === def;\n              const isWrong = submitted && matchedTerm && pairs.find((p) => p.term === matchedTerm)?.definition !== def;\n\n              return (\n                <button\n                  key={def}\n                  onClick={() => handleDefClick(def)}\n                  disabled={submitted || (!isClickable && !isUsed)}\n                  className={`w-full text-left px-3 py-2.5 rounded-lg border-2 text-xs transition-all ${\n                    submitted\n                      ? isCorrect\n                        ? \"border-green-400 bg-green-50 text-green-800\"\n                        : isWrong\n                        ? \"border-red-300 bg-red-50 text-red-700\"\n                        : \"border-gray-200 text-gray-400\"\n                      : isUsed\n                      ? \"border-brand-200 bg-brand-50/50 text-gray-500 cursor-default\"\n                      : isClickable\n                      ? \"border-brand-300 bg-brand-50 text-gray-700 cursor-pointer hover:border-brand-500\"\n                      : \"border-gray-200 text-gray-600 cursor-default\"\n                  }`}\n                >\n                  {def}\n                </button>\n              );\n            })}\n          </div>\n        </div>\n\n        {submitted && score < pairs.length && (\n          <div className=\"mt-4 p-3 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-800\">\n            <p className=\"font-medium mb-1\">Correct matches:</p>\n            {pairs.map((p) => (\n              <p key={p.term} className=\"text-xs mt-1\">\n                <span className=\"font-medium\">{p.term}</span> → {p.definition}\n              </p>\n            ))}\n          </div>\n        )}\n      </div>\n\n      <div className=\"px-5 pb-5 flex gap-3\">\n        {!submitted ? (\n          <button\n            onClick={handleSubmit}\n            disabled={!allMatched}\n            className=\"bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-brand-700 transition-colors text-sm\"\n          >\n            Check Matches\n          </button>\n        ) : (\n          <button\n            onClick={handleRetry}\n            className=\"text-brand-600 border border-brand-300 font-medium px-5 py-2.5 rounded-lg hover:bg-brand-50 transition-colors text-sm\"\n          >\n            Try Again\n          </button>\n        )}\n      </div>\n    </div>\n  );\n}\n"}}
