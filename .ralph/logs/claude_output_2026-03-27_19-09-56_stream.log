{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Coj2vMTCtT1fJJwaUVD9Nj","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { motion, AnimatePresence } from \"framer-motion\";\n     4→\n     5→interface Props {\n     6→  xp: number;\n     7→  visible?: boolean;\n     8→}\n     9→\n    10→const SPARKLES = [\n    11→  { x: -50, y: -40, delay: 0.1, size: 8 },\n    12→  { x: 50, y: -50, delay: 0.15, size: 6 },\n    13→  { x: -60, y: 10, delay: 0.05, size: 10 },\n    14→  { x: 65, y: 20, delay: 0.2, size: 7 },\n    15→  { x: -20, y: 55, delay: 0.12, size: 9 },\n    16→  { x: 30, y: 60, delay: 0.08, size: 6 },\n    17→];\n    18→\n    19→export default function XPBurst({ xp, visible = true }: Props) {\n    20→  return (\n    21→    <AnimatePresence>\n    22→      {visible && (\n    23→        <div className=\"fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 pointer-events-none\">\n    24→          {/* Sparkle particles */}\n    25→          {SPARKLES.map((s, i) => (\n    26→            <motion.div\n    27→              key={i}\n    28→              className=\"absolute rounded-full bg-yellow-400\"\n    29→              style={{\n    30→                width: s.size,\n    31→                height: s.size,\n    32→                left: \"50%\",\n    33→                top: \"50%\",\n    34→              }}\n    35→              initial={{ x: 0, y: 0, scale: 0, opacity: 1 }}\n    36→              animate={{\n    37→                x: s.x,\n    38→                y: s.y,\n    39→                scale: [0, 1.5, 0],\n    40→                opacity: [1, 1, 0],\n    41→              }}\n    42→              transition={{ duration: 0.7, delay: s.delay, ease: \"easeOut\" }}\n    43→            />\n    44→          ))}\n    45→\n    46→          {/* Main XP badge */}\n    47→          <motion.div\n    48→            initial={{ scale: 0.3, opacity: 0, y: 0 }}\n    49→            animate={{ scale: [0.3, 1.15, 1], opacity: 1, y: 0 }}\n    50→            exit={{ scale: 1, opacity: 0, y: -80 }}\n    51→            transition={{\n    52→              scale: { duration: 0.45, ease: [0.34, 1.56, 0.64, 1] },\n    53→              opacity: { duration: 0.3 },\n    54→            }}\n    55→          >\n    56→            <div className=\"bg-gradient-to-br from-brand-500 to-brand-700 text-white font-bold text-3xl px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-3 animate-glow-pulse\">\n    57→              <motion.span\n    58→                animate={{ rotate: [0, -15, 15, -10, 10, 0] }}\n    59→                transition={{ duration: 0.5, delay: 0.2 }}\n    60→              >\n    61→                ⚡\n    62→              </motion.span>\n    63→              <span>+{xp} XP</span>\n    64→            </div>\n    65→          </motion.div>\n    66→        </div>\n    67→      )}\n    68→    </AnimatePresence>\n    69→  );\n    70→}\n    71→"}]},"parent_tool_use_id":null,"session_id":"f35b7b4d-e00d-4a46-b7f3-fc8a38b8e426","uuid":"64241c71-39b0-413f-9dbe-98c4af3fd0eb","timestamp":"2026-03-28T00:10:46.882Z","tool_use_result":{"type":"text","file":{"filePath":"/root/clawd/epiphany-learn/components/gamification/XPBurst.tsx","content":"\"use client\";\n\nimport { motion, AnimatePresence } from \"framer-motion\";\n\ninterface Props {\n  xp: number;\n  visible?: boolean;\n}\n\nconst SPARKLES = [\n  { x: -50, y: -40, delay: 0.1, size: 8 },\n  { x: 50, y: -50, delay: 0.15, size: 6 },\n  { x: -60, y: 10, delay: 0.05, size: 10 },\n  { x: 65, y: 20, delay: 0.2, size: 7 },\n  { x: -20, y: 55, delay: 0.12, size: 9 },\n  { x: 30, y: 60, delay: 0.08, size: 6 },\n];\n\nexport default function XPBurst({ xp, visible = true }: Props) {\n  return (\n    <AnimatePresence>\n      {visible && (\n        <div className=\"fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 pointer-events-none\">\n          {/* Sparkle particles */}\n          {SPARKLES.map((s, i) => (\n            <motion.div\n              key={i}\n              className=\"absolute rounded-full bg-yellow-400\"\n              style={{\n                width: s.size,\n                height: s.size,\n                left: \"50%\",\n                top: \"50%\",\n              }}\n              initial={{ x: 0, y: 0, scale: 0, opacity: 1 }}\n              animate={{\n                x: s.x,\n                y: s.y,\n                scale: [0, 1.5, 0],\n                opacity: [1, 1, 0],\n              }}\n              transition={{ duration: 0.7, delay: s.delay, ease: \"easeOut\" }}\n            />\n          ))}\n\n          {/* Main XP badge */}\n          <motion.div\n            initial={{ scale: 0.3, opacity: 0, y: 0 }}\n            animate={{ scale: [0.3, 1.15, 1], opacity: 1, y: 0 }}\n            exit={{ scale: 1, opacity: 0, y: -80 }}\n            transition={{\n              scale: { duration: 0.45, ease: [0.34, 1.56, 0.64, 1] },\n              opacity: { duration: 0.3 },\n            }}\n          >\n            <div className=\"bg-gradient-to-br from-brand-500 to-brand-700 text-white font-bold text-3xl px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-3 animate-glow-pulse\">\n              <motion.span\n                animate={{ rotate: [0, -15, 15, -10, 10, 0] }}\n                transition={{ duration: 0.5, delay: 0.2 }}\n              >\n                ⚡\n              </motion.span>\n              <span>+{xp} XP</span>\n            </div>\n          </motion.div>\n        </div>\n      )}\n    </AnimatePresence>\n  );\n}\n","numLines":71,"startLine":1,"totalLines":71}}}
