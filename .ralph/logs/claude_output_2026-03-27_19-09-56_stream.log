0.1)\", color: \"#F0EFEB\" }}","           />","           <input","             type=\"password\""]},{"oldStart":109,"oldLines":20,"newStart":112,"newLines":23,"lines":["             onChange={(e) => setPassword(e.target.value)}","             required","             minLength={6}","-            className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500\"","+            className=\"w-full rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#1368CE]\"","+            style={{ background: \"rgba(255,255,255,0.05)\", border: \"1px solid rgba(255,255,255,0.1)\", color: \"#F0EFEB\" }}","           />","-          {error && <p className=\"text-xs text-red-500\">{error}</p>}","+          {error && <p className=\"text-xs\" style={{ color: \"#FF6B7A\" }}>{error}</p>}","           <button","             type=\"submit\"","             disabled={loading}","-            className=\"w-full bg-brand-600 text-white font-medium py-2 rounded-lg text-sm hover:bg-brand-700 disabled:opacity-50 transition-colors\"","+            className=\"w-full text-white font-medium py-2 rounded-lg text-sm disabled:opacity-50 transition-colors\"","+            style={{ background: \"#1368CE\" }}","           >","             {loading ? \"...\" : mode === \"signup\" ? \"Create Account\" : \"Sign In\"}","           </button>","         </form>","         <button","           onClick={() => setMode(mode === \"signup\" ? \"signin\" : \"signup\")}","-          className=\"text-xs text-gray-400 hover:text-brand-600 mt-3 w-full text-center transition-colors\"","+          className=\"text-xs mt-3 w-full text-center transition-colors\"","+          style={{ color: \"rgba(240, 239, 235, 0.4)\" }}","         >","           {mode === \"signup\" ? \"Already have an account? Sign in\" : \"No account? Create one free\"}","         </button>"]},{"oldStart":132,"oldLines":20,"newStart":138,"newLines":22,"lines":[" ","   // Default — invite to sync (non-intrusive)","   return (","-    <div className=\"bg-gray-50 border border-dashed border-gray-200 rounded-xl p-4 text-center\">","-      <p className=\"text-sm text-gray-500 mb-3\">","+    <div className=\"rounded-xl p-4 text-center\" style={{ background: \"#0A0A0A\", border: \"1px dashed rgba(255,255,255,0.1)\" }}>","+      <p className=\"text-sm mb-3\" style={{ color: \"rgba(240, 239, 235, 0.5)\" }}>","         Want your progress on all devices?","       </p>","       <div className=\"flex gap-2 justify-center\">","         <button","           onClick={() => setMode(\"signup\")}","-          className=\"text-xs bg-brand-600 text-white font-medium px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors\"","+          className=\"text-xs text-white font-medium px-4 py-2 rounded-lg transition-colors\"","+          style={{ background: \"#1368CE\" }}","         >","           Save Progress","         </button>","         <button","           onClick={() => setMode(\"signin\")}","-          className=\"text-xs border border-gray-200 text-gray-500 font-medium px-4 py-2 rounded-lg hover:border-gray-300 transition-colors\"","+          className=\"text-xs font-medium px-4 py-2 rounded-lg transition-colors\"","+          style={{ color: \"rgba(240, 239, 235, 0.6)\", border: \"1px solid rgba(255,255,255,0.1)\" }}","         >","           Sign In","         </button>"]}],"originalFile":"\"use client\";\n\nimport { useState, useEffect } from \"react\";\nimport { signUp, signIn, signOut, getCurrentUser, type SyncUser } from \"@/lib/sync\";\n\ntype Mode = \"idle\" | \"signup\" | \"signin\";\n\nexport default function AccountSync() {\n  const [user, setUser] = useState<SyncUser | null>(null);\n  const [mode, setMode] = useState<Mode>(\"idle\");\n  const [email, setEmail] = useState(\"\");\n  const [password, setPassword] = useState(\"\");\n  const [error, setError] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [success, setSuccess] = useState(false);\n  const [mounted, setMounted] = useState(false);\n\n  useEffect(() => {\n    setMounted(true);\n    getCurrentUser().then(setUser);\n  }, []);\n\n  if (!mounted) return null;\n\n  async function handleSubmit(e: React.FormEvent) {\n    e.preventDefault();\n    setError(null);\n    setLoading(true);\n\n    const result = mode === \"signup\"\n      ? await signUp(email, password)\n      : await signIn(email, password);\n\n    setLoading(false);\n\n    if (result.error) {\n      setError(result.error);\n    } else {\n      setSuccess(true);\n      const u = await getCurrentUser();\n      setUser(u);\n      setMode(\"idle\");\n      setTimeout(() => setSuccess(false), 4000);\n    }\n  }\n\n  async function handleSignOut() {\n    await signOut();\n    setUser(null);\n  }\n\n  // Signed in — show account info\n  if (user) {\n    return (\n      <div className=\"bg-white border border-gray-200 rounded-xl p-4 flex items-center justify-between\">\n        <div>\n          <p className=\"text-sm font-semibold text-gray-700\">✓ Progress synced</p>\n          <p className=\"text-xs text-gray-400\">{user.email}</p>\n        </div>\n        <button\n          onClick={handleSignOut}\n          className=\"text-xs text-gray-400 hover:text-gray-700 transition-colors\"\n        >\n          Sign out\n        </button>\n      </div>\n    );\n  }\n\n  // Success flash\n  if (success) {\n    return (\n      <div className=\"bg-green-50 border border-green-200 rounded-xl p-4 text-center\">\n        <p className=\"text-sm font-semibold text-green-700\">\n          {mode === \"signup\" ? \"✓ Account created! Progress saved.\" : \"✓ Signed in! Progress synced.\"}\n        </p>\n      </div>\n    );\n  }\n\n  // Form mode\n  if (mode !== \"idle\") {\n    return (\n      <div className=\"bg-white border border-gray-200 rounded-xl p-5\">\n        <div className=\"flex items-center justify-between mb-4\">\n          <h3 className=\"font-semibold text-gray-900 text-sm\">\n            {mode === \"signup\" ? \"Save progress across devices\" : \"Sign in to your account\"}\n          </h3>\n          <button\n            onClick={() => { setMode(\"idle\"); setError(null); }}\n            className=\"text-gray-400 hover:text-gray-700 text-lg leading-none\"\n          >\n            ×\n          </button>\n        </div>\n        <form onSubmit={handleSubmit} className=\"space-y-3\">\n          <input\n            type=\"email\"\n            placeholder=\"Email\"\n            value={email}\n            onChange={(e) => setEmail(e.target.value)}\n            required\n            className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500\"\n          />\n          <input\n            type=\"password\"\n            placeholder=\"Password\"\n            value={password}\n            onChange={(e) => setPassword(e.target.value)}\n            required\n            minLength={6}\n            className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500\"\n          />\n          {error && <p className=\"text-xs text-red-500\">{error}</p>}\n          <button\n            type=\"submit\"\n            disabled={loading}\n            className=\"w-full bg-brand-600 text-white font-medium py-2 rounded-lg text-sm hover:bg-brand-700 disabled:opacity-50 transition-colors\"\n          >\n            {loading ? \"...\" : mode === \"signup\" ? \"Create Account\" : \"Sign In\"}\n          </button>\n        </form>\n        <button\n          onClick={() => setMode(mode === \"signup\" ? \"signin\" : \"signup\")}\n          className=\"text-xs text-gray-400 hover:text-brand-600 mt-3 w-full text-center transition-colors\"\n        >\n          {mode === \"signup\" ? \"Already have an account? Sign in\" : \"No account? Create one free\"}\n        </button>\n      </div>\n    );\n  }\n\n  // Default — invite to sync (non-intrusive)\n  return (\n    <div className=\"bg-gray-50 border border-dashed border-gray-200 rounded-xl p-4 text-center\">\n      <p className=\"text-sm text-gray-500 mb-3\">\n        Want your progress on all devices?\n      </p>\n      <div className=\"flex gap-2 justify-center\">\n        <button\n          onClick={() => setMode(\"signup\")}\n          className=\"text-xs bg-brand-600 text-white font-medium px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors\"\n        >\n          Save Progress\n        </button>\n        <button\n          onClick={() => setMode(\"signin\")}\n          className=\"text-xs border border-gray-200 text-gray-500 font-medium px-4 py-2 rounded-lg hover:border-gray-300 transition-colors\"\n        >\n          Sign In\n        </button>\n      </div>\n    </div>\n  );\n}\n"}}
