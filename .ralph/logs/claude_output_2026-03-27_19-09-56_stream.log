{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01JE5byy1Arx56sNHSJB1AaZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01JHLEuLqtfsZo95e4KH9Lxn","name":"Write","input":{"file_path":"/root/clawd/epiphany-learn/components/mdx/DragDrop.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\n\ninterface Item {\n  id: string;\n  text: string;\n  correctCategory: string;\n}\n\ninterface Props {\n  id?: string;\n  instruction: string;\n  categories: string[];\n  items: Item[];\n}\n\nconst CATEGORY_COLORS = [\n  { bg: \"rgba(19, 104, 206, 0.15)\", border: \"#1368CE\", text: \"#4DA3FF\", activeBg: \"#1368CE\" },\n  { bg: \"rgba(0, 201, 183, 0.15)\", border: \"#00C9B7\", text: \"#4DFFE8\", activeBg: \"#00C9B7\" },\n  { bg: \"rgba(255, 166, 2, 0.15)\", border: \"#FFA602\", text: \"#FFD066\", activeBg: \"#FFA602\" },\n  { bg: \"rgba(255, 62, 165, 0.15)\", border: \"#FF3EA5\", text: \"#FF7EC5\", activeBg: \"#FF3EA5\" },\n];\n\nexport default function DragDrop({ instruction, categories, items }: Props) {\n  const [assignments, setAssignments] = useState<Record<string, string>>({});\n  const [submitted, setSubmitted] = useState(false);\n\n  const allAssigned = items.every((item) => assignments[item.id]);\n  const score = submitted\n    ? items.filter((item) => assignments[item.id] === item.correctCategory).length\n    : 0;\n\n  function assign(itemId: string, category: string) {\n    if (submitted) return;\n    setAssignments((prev) => ({ ...prev, [itemId]: category }));\n  }\n\n  function handleSubmit() {\n    if (!allAssigned) return;\n    setSubmitted(true);\n  }\n\n  function handleRetry() {\n    setAssignments({});\n    setSubmitted(false);\n  }\n\n  return (\n    <div className=\"my-6 rounded-2xl border border-white/[0.08] overflow-hidden\" style={{ background: \"#0A0A0A\" }}>\n      <div className=\"px-5 py-3 flex items-center justify-between\" style={{ background: \"linear-gradient(135deg, #1368CE, #0D4F9E)\" }}>\n        <span className=\"text-white font-semibold text-sm font-display\">Sort It Out</span>\n        {submitted && (\n          <span className=\"text-white/90 text-sm font-medium\">\n            {score}/{items.length} correct\n          </span>\n        )}\n      </div>\n\n      <div className=\"p-5\">\n        <p className=\"text-sm mb-4\" style={{ color: \"rgba(240, 239, 235, 0.6)\" }}>{instruction}</p>\n\n        <div className=\"space-y-2\">\n          {items.map((item) => {\n            const assigned = assignments[item.id];\n            const isCorrect = submitted && assigned === item.correctCategory;\n            const isWrong = submitted && assigned && assigned !== item.correctCategory;\n\n            return (\n              <div\n                key={item.id}\n                className=\"rounded-xl border-2 p-3 transition-all\"\n                style={{\n                  borderColor: submitted\n                    ? isCorrect ? \"#26890C\" : isWrong ? \"#E21B3C\" : \"rgba(255,255,255,0.08)\"\n                    : \"rgba(255,255,255,0.08)\",\n                  background: submitted\n                    ? isCorrect ? \"rgba(38, 137, 12, 0.1)\" : isWrong ? \"rgba(226, 27, 60, 0.1)\" : \"transparent\"\n                    : \"transparent\",\n                }}\n              >\n                <p className=\"text-sm mb-2 font-medium\" style={{ color: submitted && isWrong ? \"#FF6B7A\" : \"#F0EFEB\" }}>\n                  {item.text}\n                  {submitted && isWrong && (\n                    <span className=\"ml-2 text-xs font-normal\" style={{ color: \"#FF6B7A\" }}>\n                      (correct: {item.correctCategory})\n                    </span>\n                  )}\n                  {submitted && isCorrect && (\n                    <span className=\"ml-2 text-xs\" style={{ color: \"#4CD929\" }}>✓</span>\n                  )}\n                </p>\n                <div className=\"flex flex-wrap gap-2\">\n                  {categories.map((cat, ci) => {\n                    const c = CATEGORY_COLORS[ci % CATEGORY_COLORS.length];\n                    return (\n                      <button\n                        key={cat}\n                        onClick={() => assign(item.id, cat)}\n                        disabled={submitted}\n                        className=\"px-3 py-1 rounded-lg text-xs font-medium border transition-all\"\n                        style={{\n                          background: assigned === cat\n                            ? submitted ? (isCorrect ? \"#26890C\" : \"#E21B3C\") : c.activeBg\n                            : c.bg,\n                          color: assigned === cat ? \"#fff\" : c.text,\n                          borderColor: assigned === cat\n                            ? submitted ? (isCorrect ? \"#26890C\" : \"#E21B3C\") : c.border\n                            : \"rgba(255,255,255,0.06)\",\n                          cursor: submitted ? \"default\" : \"pointer\",\n                        }}\n                      >\n                        {cat}\n                      </button>\n                    );\n                  })}\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n\n      <div className=\"px-5 pb-5 flex gap-3\">\n        {!submitted ? (\n          <button\n            onClick={handleSubmit}\n            disabled={!allAssigned}\n            className=\"text-white font-semibold px-5 py-2.5 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed transition-colors text-sm\"\n            style={{ background: \"#1368CE\" }}\n          >\n            Check Answers\n          </button>\n        ) : (\n          <button\n            onClick={handleRetry}\n            className=\"font-medium px-5 py-2.5 rounded-lg transition-colors text-sm border\"\n            style={{ color: \"#4DA3FF\", borderColor: \"rgba(19, 104, 206, 0.4)\" }}\n          >\n            Try Again\n          </button>\n        )}\n      </div>\n    </div>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":7313,"cache_read_input_tokens":71571,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7313},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f35b7b4d-e00d-4a46-b7f3-fc8a38b8e426","uuid":"9224c2a9-ac52-4e1e-a937-c7976d105852"}
