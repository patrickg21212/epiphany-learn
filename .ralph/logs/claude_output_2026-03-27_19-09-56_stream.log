{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014sSeo68pUV2L3HjcgiQAtc","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useState } from \"react\";\n     4→\n     5→interface Item {\n     6→  id: string;\n     7→  text: string;\n     8→  correctCategory: string;\n     9→}\n    10→\n    11→interface Props {\n    12→  id?: string;\n    13→  instruction: string;\n    14→  categories: string[];\n    15→  items: Item[];\n    16→}\n    17→\n    18→export default function DragDrop({ instruction, categories, items }: Props) {\n    19→  const [assignments, setAssignments] = useState<Record<string, string>>({});\n    20→  const [submitted, setSubmitted] = useState(false);\n    21→\n    22→  const allAssigned = items.every((item) => assignments[item.id]);\n    23→  const score = submitted\n    24→    ? items.filter((item) => assignments[item.id] === item.correctCategory).length\n    25→    : 0;\n    26→\n    27→  function assign(itemId: string, category: string) {\n    28→    if (submitted) return;\n    29→    setAssignments((prev) => ({ ...prev, [itemId]: category }));\n    30→  }\n    31→\n    32→  function handleSubmit() {\n    33→    if (!allAssigned) return;\n    34→    setSubmitted(true);\n    35→  }\n    36→\n    37→  function handleRetry() {\n    38→    setAssignments({});\n    39→    setSubmitted(false);\n    40→  }\n    41→\n    42→  return (\n    43→    <div className=\"my-6 rounded-2xl border border-gray-200 bg-white overflow-hidden\">\n    44→      <div className=\"bg-brand-600 px-5 py-3 flex items-center justify-between\">\n    45→        <span className=\"text-white font-semibold text-sm\">Sort It Out</span>\n    46→        {submitted && (\n    47→          <span className=\"text-white/90 text-sm font-medium\">\n    48→            {score}/{items.length} correct\n    49→          </span>\n    50→        )}\n    51→      </div>\n    52→\n    53→      <div className=\"p-5\">\n    54→        <p className=\"text-sm text-gray-600 mb-4\">{instruction}</p>\n    55→\n    56→        <div className=\"space-y-2\">\n    57→          {items.map((item) => {\n    58→            const assigned = assignments[item.id];\n    59→            const isCorrect = submitted && assigned === item.correctCategory;\n    60→            const isWrong = submitted && assigned && assigned !== item.correctCategory;\n    61→\n    62→            return (\n    63→              <div\n    64→                key={item.id}\n    65→                className={`rounded-xl border-2 p-3 transition-all ${\n    66→                  submitted\n    67→                    ? isCorrect\n    68→                      ? \"border-green-300 bg-green-50\"\n    69→                      : isWrong\n    70→                      ? \"border-red-300 bg-red-50\"\n    71→                      : \"border-gray-200\"\n    72→                    : \"border-gray-200\"\n    73→                }`}\n    74→              >\n    75→                <p className={`text-sm mb-2 font-medium ${submitted && isWrong ? \"text-red-700\" : \"text-gray-800\"}`}>\n    76→                  {item.text}\n    77→                  {submitted && isWrong && (\n    78→                    <span className=\"ml-2 text-xs font-normal text-red-600\">\n    79→                      (correct: {item.correctCategory})\n    80→                    </span>\n    81→                  )}\n    82→                  {submitted && isCorrect && (\n    83→                    <span className=\"ml-2 text-xs text-green-600\">✓</span>\n    84→                  )}\n    85→                </p>\n    86→                <div className=\"flex flex-wrap gap-2\">\n    87→                  {categories.map((cat) => (\n    88→                    <button\n    89→                      key={cat}\n    90→                      onClick={() => assign(item.id, cat)}\n    91→                      disabled={submitted}\n    92→                      className={`px-3 py-1 rounded-lg text-xs font-medium border transition-all ${\n    93→                        assigned === cat\n    94→                          ? submitted\n    95→                            ? isCorrect\n    96→                              ? \"bg-green-500 text-white border-green-500\"\n    97→                              : \"bg-red-400 text-white border-red-400\"\n    98→                            : \"bg-brand-600 text-white border-brand-600\"\n    99→                          : \"bg-gray-50 text-gray-600 border-gray-300 hover:border-brand-400 hover:bg-brand-50 disabled:cursor-default\"\n   100→                      }`}\n   101→                    >\n   102→                      {cat}\n   103→                    </button>\n   104→                  ))}\n   105→                </div>\n   106→              </div>\n   107→            );\n   108→          })}\n   109→        </div>\n   110→      </div>\n   111→\n   112→      <div className=\"px-5 pb-5 flex gap-3\">\n   113→        {!submitted ? (\n   114→          <button\n   115→            onClick={handleSubmit}\n   116→            disabled={!allAssigned}\n   117→            className=\"bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-brand-700 transition-colors text-sm\"\n   118→          >\n   119→            Check Answers\n   120→          </button>\n   121→        ) : (\n   122→          <button\n   123→            onClick={handleRetry}\n   124→            className=\"text-brand-600 border border-brand-300 font-medium px-5 py-2.5 rounded-lg hover:bg-brand-50 transition-colors text-sm\"\n   125→          >\n   126→            Try Again\n   127→          </button>\n   128→        )}\n   129→      </div>\n   130→    </div>\n   131→  );\n   132→}\n   133→"}]},"parent_tool_use_id":null,"session_id":"f35b7b4d-e00d-4a46-b7f3-fc8a38b8e426","uuid":"de6dd8a1-729b-4e49-a35e-1397efed62a7","timestamp":"2026-03-28T00:10:39.534Z","tool_use_result":{"type":"text","file":{"filePath":"/root/clawd/epiphany-learn/components/mdx/DragDrop.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\n\ninterface Item {\n  id: string;\n  text: string;\n  correctCategory: string;\n}\n\ninterface Props {\n  id?: string;\n  instruction: string;\n  categories: string[];\n  items: Item[];\n}\n\nexport default function DragDrop({ instruction, categories, items }: Props) {\n  const [assignments, setAssignments] = useState<Record<string, string>>({});\n  const [submitted, setSubmitted] = useState(false);\n\n  const allAssigned = items.every((item) => assignments[item.id]);\n  const score = submitted\n    ? items.filter((item) => assignments[item.id] === item.correctCategory).length\n    : 0;\n\n  function assign(itemId: string, category: string) {\n    if (submitted) return;\n    setAssignments((prev) => ({ ...prev, [itemId]: category }));\n  }\n\n  function handleSubmit() {\n    if (!allAssigned) return;\n    setSubmitted(true);\n  }\n\n  function handleRetry() {\n    setAssignments({});\n    setSubmitted(false);\n  }\n\n  return (\n    <div className=\"my-6 rounded-2xl border border-gray-200 bg-white overflow-hidden\">\n      <div className=\"bg-brand-600 px-5 py-3 flex items-center justify-between\">\n        <span className=\"text-white font-semibold text-sm\">Sort It Out</span>\n        {submitted && (\n          <span className=\"text-white/90 text-sm font-medium\">\n            {score}/{items.length} correct\n          </span>\n        )}\n      </div>\n\n      <div className=\"p-5\">\n        <p className=\"text-sm text-gray-600 mb-4\">{instruction}</p>\n\n        <div className=\"space-y-2\">\n          {items.map((item) => {\n            const assigned = assignments[item.id];\n            const isCorrect = submitted && assigned === item.correctCategory;\n            const isWrong = submitted && assigned && assigned !== item.correctCategory;\n\n            return (\n              <div\n                key={item.id}\n                className={`rounded-xl border-2 p-3 transition-all ${\n                  submitted\n                    ? isCorrect\n                      ? \"border-green-300 bg-green-50\"\n                      : isWrong\n                      ? \"border-red-300 bg-red-50\"\n                      : \"border-gray-200\"\n                    : \"border-gray-200\"\n                }`}\n              >\n                <p className={`text-sm mb-2 font-medium ${submitted && isWrong ? \"text-red-700\" : \"text-gray-800\"}`}>\n                  {item.text}\n                  {submitted && isWrong && (\n                    <span className=\"ml-2 text-xs font-normal text-red-600\">\n                      (correct: {item.correctCategory})\n                    </span>\n                  )}\n                  {submitted && isCorrect && (\n                    <span className=\"ml-2 text-xs text-green-600\">✓</span>\n                  )}\n                </p>\n                <div className=\"flex flex-wrap gap-2\">\n                  {categories.map((cat) => (\n                    <button\n                      key={cat}\n                      onClick={() => assign(item.id, cat)}\n                      disabled={submitted}\n                      className={`px-3 py-1 rounded-lg text-xs font-medium border transition-all ${\n                        assigned === cat\n                          ? submitted\n                            ? isCorrect\n                              ? \"bg-green-500 text-white border-green-500\"\n                              : \"bg-red-400 text-white border-red-400\"\n                            : \"bg-brand-600 text-white border-brand-600\"\n                          : \"bg-gray-50 text-gray-600 border-gray-300 hover:border-brand-400 hover:bg-brand-50 disabled:cursor-default\"\n                      }`}\n                    >\n                      {cat}\n                    </button>\n                  ))}\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n\n      <div className=\"px-5 pb-5 flex gap-3\">\n        {!submitted ? (\n          <button\n            onClick={handleSubmit}\n            disabled={!allAssigned}\n            className=\"bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-brand-700 transition-colors text-sm\"\n          >\n            Check Answers\n          </button>\n        ) : (\n          <button\n            onClick={handleRetry}\n            className=\"text-brand-600 border border-brand-300 font-medium px-5 py-2.5 rounded-lg hover:bg-brand-50 transition-colors text-sm\"\n          >\n            Try Again\n          </button>\n        )}\n      </div>\n    </div>\n  );\n}\n","numLines":133,"startLine":1,"totalLines":133}}}
