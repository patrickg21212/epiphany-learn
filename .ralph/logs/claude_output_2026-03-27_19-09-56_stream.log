{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H1SWMUBfjuNzAKLLJWZPo2","type":"tool_result","content":"The file /root/clawd/epiphany-learn/components/gamification/Confetti.tsx has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"f35b7b4d-e00d-4a46-b7f3-fc8a38b8e426","uuid":"aadbb528-40fb-43c3-9dac-87119b2f647b","timestamp":"2026-03-28T00:12:55.649Z","tool_use_result":{"filePath":"/root/clawd/epiphany-learn/components/gamification/Confetti.tsx","oldString":"const COLORS = [\n  \"#4f61fa\", \"#758aff\", \"#f59e0b\", \"#10b981\", \"#f43f5e\",\n  \"#8b5cf6\", \"#06b6d4\", \"#84cc16\", \"#fb923c\", \"#ec4899\",\n];","newString":"const COLORS = [\n  \"#E21B3C\", \"#1368CE\", \"#FFA602\", \"#26890C\", \"#00C9B7\",\n  \"#FF3EA5\", \"#EB670F\", \"#4DA3FF\", \"#4CD929\", \"#FFD066\",\n];","originalFile":"\"use client\";\n\nimport { useMemo } from \"react\";\nimport { motion, useReducedMotion } from \"framer-motion\";\n\ninterface ConfettiPiece {\n  id: number;\n  x: number;\n  color: string;\n  size: number;\n  duration: number;\n  delay: number;\n  rotation: number;\n  shape: \"rect\" | \"circle\" | \"triangle\";\n}\n\nconst COLORS = [\n  \"#4f61fa\", \"#758aff\", \"#f59e0b\", \"#10b981\", \"#f43f5e\",\n  \"#8b5cf6\", \"#06b6d4\", \"#84cc16\", \"#fb923c\", \"#ec4899\",\n];\n\ninterface Props {\n  count?: number;\n  active?: boolean;\n}\n\nexport default function Confetti({ count = 60, active = true }: Props) {\n  const prefersReducedMotion = useReducedMotion();\n  const pieces = useMemo<ConfettiPiece[]>(() => {\n    return Array.from({ length: count }, (_, i) => ({\n      id: i,\n      x: Math.random() * 100,\n      color: COLORS[Math.floor(Math.random() * COLORS.length)],\n      size: 6 + Math.random() * 8,\n      duration: 1.8 + Math.random() * 1.4,\n      delay: Math.random() * 0.8,\n      rotation: 360 + Math.random() * 720,\n      shape: ([\"rect\", \"circle\", \"triangle\"] as const)[Math.floor(Math.random() * 3)],\n    }));\n  }, [count]);\n\n  if (!active || prefersReducedMotion) return null;\n\n  return (\n    <div className=\"fixed inset-0 z-40 pointer-events-none overflow-hidden\">\n      {pieces.map((p) => (\n        <motion.div\n          key={p.id}\n          className=\"absolute\"\n          style={{\n            left: `${p.x}%`,\n            top: -20,\n            width: p.shape === \"circle\" ? p.size : p.size,\n            height: p.shape === \"triangle\" ? 0 : p.size,\n            backgroundColor: p.shape !== \"triangle\" ? p.color : \"transparent\",\n            borderRadius: p.shape === \"circle\" ? \"50%\" : p.shape === \"rect\" ? 2 : 0,\n            borderLeft: p.shape === \"triangle\" ? `${p.size / 2}px solid transparent` : undefined,\n            borderRight: p.shape === \"triangle\" ? `${p.size / 2}px solid transparent` : undefined,\n            borderBottom: p.shape === \"triangle\" ? `${p.size}px solid ${p.color}` : undefined,\n          }}\n          initial={{ y: -20, rotate: 0, opacity: 1 }}\n          animate={{\n            y: \"105vh\",\n            rotate: p.rotation,\n            opacity: [1, 1, 0],\n          }}\n          transition={{\n            duration: p.duration,\n            delay: p.delay,\n            ease: \"easeIn\",\n            opacity: { times: [0, 0.7, 1] },\n          }}\n        />\n      ))}\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":15,"oldLines":8,"newStart":15,"newLines":8,"lines":[" }"," "," const COLORS = [","-  \"#4f61fa\", \"#758aff\", \"#f59e0b\", \"#10b981\", \"#f43f5e\",","-  \"#8b5cf6\", \"#06b6d4\", \"#84cc16\", \"#fb923c\", \"#ec4899\",","+  \"#E21B3C\", \"#1368CE\", \"#FFA602\", \"#26890C\", \"#00C9B7\",","+  \"#FF3EA5\", \"#EB670F\", \"#4DA3FF\", \"#4CD929\", \"#FFD066\","," ];"," "," interface Props {"]}],"userModified":false,"replaceAll":false}}
