p: \"50%\",\n              }}\n              initial={{ x: 0, y: 0, scale: 0, opacity: 1 }}\n              animate={{\n                x: s.x,\n                y: s.y,\n                scale: [0, 1.5, 0],\n                opacity: [1, 1, 0],\n              }}\n              transition={{ duration: 0.7, delay: s.delay, ease: \"easeOut\" }}\n            />\n          ))}\n\n          {/* Main XP badge */}\n          <motion.div\n            initial={{ scale: 0.3, opacity: 0, y: 0 }}\n            animate={{ scale: [0.3, 1.15, 1], opacity: 1, y: 0 }}\n            exit={{ scale: 1, opacity: 0, y: -80 }}\n            transition={{\n              scale: { duration: 0.45, ease: [0.34, 1.56, 0.64, 1] },\n              opacity: { duration: 0.3 },\n            }}\n          >\n            <div className=\"bg-gradient-to-br from-brand-500 to-brand-700 text-white font-bold text-3xl px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-3 animate-glow-pulse\">\n              <motion.span\n                animate={{ rotate: [0, -15, 15, -10, 10, 0] }}\n                transition={{ duration: 0.5, delay: 0.2 }}\n              >\n                ⚡\n              </motion.span>\n              <span>+{xp} XP</span>\n            </div>\n          </motion.div>\n        </div>\n      )}\n    </AnimatePresence>\n  );\n}\n","structuredPatch":[{"oldStart":54,"oldLines":7,"newStart":54,"newLines":7,"lines":["               opacity: { duration: 0.3 },","             }}","           >","-            <div className=\"bg-gradient-to-br from-brand-500 to-brand-700 text-white font-bold text-3xl px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-3 animate-glow-pulse\">","+            <div className=\"text-white font-bold font-display text-3xl px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-3\" style={{ background: \"linear-gradient(135deg, #FFA602, #EB670F)\", boxShadow: \"0 0 40px rgba(255, 166, 2, 0.4)\" }}>","               <motion.span","                 animate={{ rotate: [0, -15, 