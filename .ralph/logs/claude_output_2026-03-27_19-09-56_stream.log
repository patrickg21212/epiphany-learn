[0.08] overflow-hidden\" style={{ background: \"#0A0A0A\" }}>\n      <div className=\"px-5 py-3 flex items-center justify-between\" style={{ background: \"linear-gradient(135deg, #FF3EA5, #CC3284)\" }}>\n        <span className=\"text-white font-semibold text-sm font-display\">Match the Terms</span>\n        {submitted && (\n          <span className=\"text-white/90 text-sm font-medium\">\n            {score}/{pairs.length} correct\n          </span>\n        )}\n      </div>\n\n      <div className=\"p-5\">\n        {instruction && (\n          <p className=\"text-sm mb-4\" style={{ color: \"rgba(240, 239, 235, 0.6)\" }}>{instruction}</p>\n        )}\n\n        {!submitted && (\n          <p className=\"text-xs mb-3\" style={{ color: \"rgba(240, 239, 235, 0.35)\" }}>\n            {selectedTerm ? `Select a definition for \"${selectedTerm}\"` : \"Click a term, then click its matching definition.\"}\n          </p>\n        )}\n\n        <div className=\"grid grid-cols-2 gap-3\">\n          {/* Terms column */}\n          <div className=\"space-y-2\">\n            <p className=\"text-xs font-semibold uppercase tracking-wide mb-1\" style={{ color: \"rgba(240, 239, 235, 0.4)\" }}>Terms</p>\n            {pairs.map((p) => {\n              const isSelected = selectedTerm === p.term;\n              const isMatched = !!matches[p.term];\n              const isCorrect = submitted && matches[p.term] === p.definition;\n              const isWrong = submitted && matches[p.term] !== p.definition;\n\n              return (\n                <button\n                  key={p.term}\n                  onClick={() => handleTermClick(p.term)}\n                  disabled={submitted}\n                  className=\"w-full text-left px-3 py-2.5 rounded-lg border-2 text-sm font-medium transition-all\"\n                  style={{\n                    borderColor: submitted\n                      ? isCorrect ? \"#26890C\" : isWrong ? \"#E21B3C\" : \"rgba(255,255,255,0.06)\"\n                      : isSelected ? \"#FF3EA5\" : isMatched ? \"rgba(255, 62, 165, 0.3)\" : \"rgba(255,255,255,0.06)\",\n                    background: submitted\n                      ? isCorrect ? \"rgba(38, 137, 12, 0.1)\" : isWrong ? \"rgba(226, 27, 60, 0.1)\" : \"transparent\"\n                      : isSelected ? \"rgba(255, 62, 165, 0.1)\" : isMatched ? \"rgba(255, 62, 165, 0.05)\" : \"transparent\",\n                    color: submitted\n                      ? isCorrect ? \"#4CD929\" : isWrong ? \"#FF6B7A\" : \"rgba(240,239,235,0.3)\"\n                      : isSelected ? \"#FF7EC5\" : \"#F0EFEB\",\n                    cursor: submitted ? \"default\" : \"pointer\",\n                  }}\n                >\n                  {p.term}\n                  {isMatched && !submitted && <span className=\"ml-1 text-xs\" style={{ color: \"#FF3EA5\" }}>✓</span>}\n                  {submitted && isCorrect && <span className=\"ml-1\" style={{ color: \"#4CD929\" }}>✓</span>}\n                </button>\n              );\n            })}\n          </div>\n\n          {/* Definitions column */}\n          <div className=\"space-y-2\">\n            <p className=\"text-xs font-semibold uppercase tracking-wide mb-1\" style={{ color: \"rgba(240, 239, 235, 0.4)\" }}>Definitions</p>\n            {shuffledDefs.map((def) => {\n              const isUsed = matchedDefs.has(def);\n              const isClickable = !!selectedTerm && !isUsed;\n              const matchedTerm = Object.entries(matches).find(([, d]) => d === def)?.[0];\n              const isCorrect = submitted && matchedTerm && pairs.find((p) => p.term === matchedTerm)?.definition === def;\n              const isWrong = submitted && matchedTerm && pairs.find((p) => p.term === matchedTerm)?.definition !== def;\n\n              return (\n                <button\n                  key={def}\n                  onClick={() => handleDefClick(def)}\n                  disabled={submitted || (!isClickable && !isUsed)}\n                  className=\"w-full text-left px-3 py-2.5 rounded-lg border-2 text-xs transition-all\"\n                  style={{\n                    borderColor: submitted\n                      ? isCorrect ? \"#26890C\" : isWrong ? \"#E21B3C\" : \"rgba(255,255,255,0.06)\"\n                      : isUsed ? \"rgba(255, 62, 165, 0.2)\" : isClickable ? \"rgba(255, 62, 165, 0.4)\" : \"rgba(255,255,255,0.06)\",\n                    background: submitted\n                      ? isCorrect ? \"rgba(38, 137, 12, 0.1)\" : isWrong ? \"rgba(226, 27, 60, 0.1)\" : \"transparent\"\n                      : isClickable ? \"rgba(255, 62, 165, 0.05)\" : \"transparent\",\n                    color: submitted\n                      ? isCorrect ? \"#4CD929\" : isWrong ? \"#FF6B7A\" : \"rgba(240,239,235,0.3)\"\n                      : isUsed ? \"rgba(240, 239, 235, 0.4)\" : \"rgba(240, 239, 235, 0.7)\",\n                    cursor: submitted ? \"default\" : isClickable ? \"pointer\" : \"default\",\n                  }}\n                >\n                  {def}\n                </button>\n              );\n            })}\n          </div>\n        </div>\n\n        {submitted && score < pairs.length && (\n          <div className=\"mt-4 p-3 rounded-lg text-sm\" style={{ background: \"rgba(255, 166, 2, 0.1)\", border: \"1px solid rgba(255, 166, 2, 0.2)\", color: \"#FFD066\" }}>\n            <p className=\"font-medium mb-1\">Correct matches:</p>\n            {pairs.map((p) => (\n              <p key={p.term} className=\"text-xs mt-1\">\n                <span className=\"font-medium\" style={{ color: \"#F0EFEB\" }}>{p.term}</span> <span style={{ color: \"rgba(240,239,235,0.4)\" }}>→</span> {p.definition}\n              </p>\n            ))}\n          </div>\n        )}\n      </div>\n\n      <div className=\"px-5 pb-5 flex gap-3\">\n        {!submitted ? (\n          <button\n            onClick={handleSubmit}\n            disabled={!allMatched}\n            className=\"text-white font-semibold px-5 py-2.5 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed transition-colors text-sm\"\n            style={{ background: \"#FF3EA5\" }}\n          >\n            Check Matches\n          </button>\n        ) : (\n          <button\n            onClick={handleRetry}\n            className=\"font-medium px-5 py-2.5 rounded-lg transition-colors text-sm border\"\n            style={{ color: \"#FF7EC5\", borderColor: \"rgba(255, 62, 165, 0.4)\" }}\n          >\n            Try Again\n          </button>\n        )}\n      </div>\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":53,"oldLines":9,"newStart":53,"newLines":9,"lines":["   }"," ","   return (","-    <div className=\"my-6 rounded-2xl border border-gray-200 bg-white overflow-hidden\">","-      <div className=\"bg-brand-600 px-5 py-3 flex items-center justify-between\">","-        <span className=\"text-white font-semibold text-sm\">Match the Terms</span>","+    <div className=\"my-6 rounded-2xl border border-white/[0.08] overflow-hidden\" style={{ background: \"#0A0A0A\" }}>","+      <div className=\"px-5 py-3 flex items-center justify-between\" style={{ background: \"linear-gradient(135deg, #FF3EA5, #CC3284)\" }}>","+        <span className=\"text-white font-semibold text-sm font-display\">Match the Terms</span>","         {submitted && (","           <span className=\"text-white/90 text-sm font-medium\">","             {score}/{pairs.length} correct"]},{"oldStart":65,"oldLines":11,"newStart":65,"newLines":11,"lines":[" ","       <div className=\"p-5\">","         {instruction && (","-          <p className=\"text-sm text-gray-600 mb-4\">{instruction}</p>","+          <p className=\"text-sm mb-4\" style={{ color: \"rgba(240, 239, 235, 0.6)\" }}>{instruction}</p>","         )}"," ","         {!submitted && (","-          <p className=\"text-xs text-gray-400 mb-3\">","+          <p className=\"text-xs mb-3\" style={{ color: \"rgba(240, 239, 235, 0.35)\" }}>","             {selectedTerm ? `Select a definition for