 className=\"text-white/90 text-sm font-medium\">\n    53→            {score}/{blanks.length} correct\n    54→          </span>\n    55→        )}\n    56→      </div>\n    57→\n    58→      <div className=\"p-5\">\n    59→        <p className=\"text-sm text-gray-700 leading-loose\">\n    60→          {parts.map((part, i) => {\n    61→            const blank = blanks[i];\n    62→            return (\n    63→              <span key={i}>\n    64→                <span dangerouslySetInnerHTML={{ __html: part.replace(/`([^`]+)`/g, '<code class=\"bg-gray-100 text-brand-700 px-1 rounded text-sm font-mono\">$1</code>') }} />\n    65→                {blank && (\n    66→                  <span className=\"inline-flex flex-col items-start mx-1 align-baseline\">\n    67→                    <input\n    68→                      type=\"text\"\n    69→                      value={inputs[blank.id] ?? \"\"}\n    70→                      onChange={(e) => setInput(blank.id, e.target.value)}\n    71→                      disabled={checked}\n    72→                      placeholder=\"___\"\n    73→                      className={`border-b-2 px-1 py-0.5 text-sm font-medium bg-transparent outline-none transition-colors min-w-16 ${\n    74→                        checked\n    75→                          ? isCorrect(blank)\n    76→                            ? \"border-green-400 text-green-700\"\n    77→                            : \"border-red-400 text-red-700\"\n    78→                          : \"border-brand-400 focus:border-brand-600 text-gray-900\"\n    79→                      }`}\n    80→                    />\n    81→                    {checked && !isCorrect(blank) && (\n    82→                      <span className=\"text-xs text-red-500 mt-0.5\">{blank.answer}</span>\n    83→                    )}\n    84→                  </span>\n    85→                )}\n    86→              </span>\n    87→            );\n    88→          })}\n    89→        </p>\n    90→      </div>\n    91→\n    92→      <div className=\"px-5 pb-5 flex gap-3\">\n    93→        {!checked ? (\n    94→          <button\n    95→            onClick={handleCheck}\n    96→            disabled={!allFilled}\n    97→            className=\"bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-brand-700 transition-colors text-sm\"\n    98→          >\n    99→            Check Answer\n   100→          </button>\n   101→        ) : (\n   102→          <button\n   103→            onClick={handleRetry}\n   104→            className=\"text-brand-600 border border-brand-300 font-medium px-5 py-2.5 rounded-lg hover:bg-brand-50 transition-colors text-sm\"\n   105→          >\n   106→            Try Again\n   107→          </button>\n   108→        )}\n   109→      </div>\n   110→    </div>\n   111→  );\n   112→}\n   113→"}]},"parent_tool_use_id":null,"session_id":"f35b7b4d-e00d-4a46-b7f3-fc8a38b8e426","uuid":"8b0ede42-b6bf-45a8-9da5-5dcd527fcfb8","timestamp":"2026-03-28T00:10:39.953Z","tool_use_result":{"type":"text","file":{"filePath":"/root/clawd/epiphany-learn/components/mdx/FillBlank.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\n\ninterface Blank {\n  id: string;\n  answer: string;\n  acceptedAnswers: string[];\n}\n\ninterface Props {\n  id?: string;\n  template: string;\n  blanks: Blank[];\n}\n\nexport default function FillBlank({ template, blanks }: Props) {\n  const [inputs, setInputs] = useState<Record<string, string>>({});\n  const [checked, setChecked] = useState(false);\n\n  // Replace each ___ in template with an input slot (in order of blanks array)\n  const parts = template.split(\"___\");\n\n  function setInput(blankId: string, value: string) {\n    if (checked) return;\n    setInputs((prev) => ({ ...prev, [blankId]: value }));\n  }\n\n  function isCorrect(blank: Blank): boolean {\n    const val = (inputs[blank.id] ?? \"\").trim().toLowerCase();\n    return blank.acceptedAnswers.some((a) => a.toLowerCase() === val);\n  }\n\n  const allFilled = blanks.every((b) => (inputs[b.id] ?? \"\").trim().length > 0);\n  const score = checked ? blanks.filter(isCorrect).length : 0;\n\n  function handleCheck() {\n    if (!allFilled) return;\n    setChecked(true);\n  }\n\n  function handleRetry() {\n    setInputs({});\n    setChecked(false);\n  }\n\n  return (\n    <div className=\"my-6 rounded-2xl border border-gray-200 bg-white overflow-hidden\">\n      <div className=\"bg-brand-600 px-5 py-3 flex items-center justify-between\">\n        <span className=\"text-white font-semibold text-sm\">Fill in the Blank</span>\n        {checked && (\n          <span className=\"text-white/90 text-sm font-medium\">\n            {score}/{blanks.length} correct\n          </span>\n        )}\n      </div>\n\n      <div className=\"p-5\">\n        <p className=\"text-sm text-gray-700 leading-loose\">\n          {parts.map((part, i) => {\n            const blank = blanks[i];\n            return (\n              <span key={i}>\n                <span dangerouslySetInnerHTML={{ __html: part.replace(/`([^`]+)`/g, '<code class=\"bg-gray-100 text-brand-700 px-1 rounded text-sm font-mono\">$1</code>') }} />\n                {blank && (\n                  <span className=\"inline-flex flex-col items-start mx-1 align-baseline\">\n                    <input\n                      type=\"text\"\n                      value={inputs[blank.id] ?? \"\"}\n                      onChange={(e) => setInput(blank.id, e.target.value)}\n                      disabled={checked}\n                      placeholder=\"___\"\n                      className={`border-b-2 px-1 py-0.5 text-sm font-medium bg-transparent outline-none transition-colors min-w-16 ${\n                        checked\n                          ? isCorrect(blank)\n                            ? \"border-green-400 text-green-700\"\n                            : \"border-red-400 text-red-700\"\n                          : \"border-brand-400 focus:border-brand-600 text-gray-900\"\n                      }`}\n                    />\n                    {checked && !isCorrect(blank) && (\n                      <span className=\"text-xs text-red-500 mt-0.5\">{blank.answer}</span>\n                    )}\n                  </span>\n                )}\n              </span>\n            );\n          })}\n        </p>\n      </div>\n\n      <div className=\"px-5 pb-5 flex gap-3\">\n        {!checked ? (\n          <button\n            onClick={handleCheck}\n            disabled={!allFilled}\n            className=\"bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-brand-700 transition-colors text-sm\"\n          >\n            Check Answer\n          </button>\n        ) : (\n          <button\n            onClick={handleRetry}\n            className=\"text-brand-600 border border-brand-300 font-medium px-5 py-2.5 rounded-lg hover:bg-brand-50 transition-colors text-sm\"\n          >\n            Try Again\n          </button>\n        )}\n      </div>\n    </div>\n  );\n}\n","numLines":113,"startLine":1,"totalLines":113}}}
