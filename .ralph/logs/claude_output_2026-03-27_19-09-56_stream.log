                )}\n                  <button\n                    onClick={onDismiss}\n                    className=\"block w-full text-center text-sm py-2 transition-colors\"\n                    style={{ color: \"rgba(240, 239, 235, 0.4)\" }}\n                  >\n                    Close\n                  </button>\n                </motion.div>\n              </div>\n            </motion.div>\n          </motion.div>\n        </>\n      )}\n    </AnimatePresence>\n  );\n}\n\nfunction StatCard({\n  icon,\n  value,\n  label,\n  color,\n}: {\n  icon: string;\n  value: string;\n  label: string;\n  color: string;\n}) {\n  return (\n    <div\n      className=\"rounded-xl p-3 text-center\"\n      style={{ background: `${color}15`, border: `1px solid ${color}30` }}\n    >\n      <div className=\"text-2xl mb-1\">{icon}</div>\n      <div className=\"font-bold font-display text-lg leading-tight\" style={{ color }}>{value}</div>\n      <div className=\"text-xs mt-0.5\" style={{ color: \"rgba(240, 239, 235, 0.5)\" }}>{label}</div>\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":43,"oldLines":7,"newStart":43,"newLines":7,"lines":["             initial={{ opacity: 0 }}","             animate={{ opacity: 1 }}","             exit={{ opacity: 0 }}","-            className=\"fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4\"","+            className=\"fixed inset-0 z-50 bg-black/70 backdrop-blur-sm flex items-center justify-center p-4\"","             onClick={onDismiss}","           >","             {/* Card */}"]},{"oldStart":53,"oldLines":10,"newStart":53,"newLines":11,"lines":["               exit={{ scale: 0.8, opacity: 0, y: 20 }}","               transition={{ type: \"spring\", stiffness: 350, damping: 28 }}","               onClick={(e) => e.stopPropagation()}","-              className=\"bg-white rounded-3xl shadow-2xl max-w-md w-full overflow-hidden\"","+              className=\"rounded-3xl max-w-md w-full overflow-hidden\"