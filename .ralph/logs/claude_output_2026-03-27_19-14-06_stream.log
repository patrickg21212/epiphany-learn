{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BppT1rqrWWjHSnWCuoQhh3","type":"tool_result","content":"The file /root/clawd/epiphany-learn/components/gamification/XPBurst.tsx has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"f35b7b4d-e00d-4a46-b7f3-fc8a38b8e426","uuid":"ddb7f107-60f2-4f0c-a538-d8e3a25c6705","timestamp":"2026-03-28T00:14:38.393Z","tool_use_result":{"filePath":"/root/clawd/epiphany-learn/components/gamification/XPBurst.tsx","oldString":"              className=\"absolute rounded-full\"\n              style={{ background: \"#FFA602\" }}\n              style={{\n                width: s.size,\n                height: s.size,\n                left: \"50%\",\n                top: \"50%\",\n              }}","newString":"              className=\"absolute rounded-full\"\n              style={{\n                background: \"#FFA602\",\n                width: s.size,\n                height: s.size,\n                left: \"50%\",\n                top: \"50%\",\n              }}","originalFile":"\"use client\";\n\nimport { motion, AnimatePresence } from \"framer-motion\";\n\ninterface Props {\n  xp: number;\n  visible?: boolean;\n}\n\nconst SPARKLES = [\n  { x: -50, y: -40, delay: 0.1, size: 8 },\n  { x: 50, y: -50, delay: 0.15, size: 6 },\n  { x: -60, y: 10, delay: 0.05, size: 10 },\n  { x: 65, y: 20, delay: 0.2, size: 7 },\n  { x: -20, y: 55, delay: 0.12, size: 9 },\n  { x: 30, y: 60, delay: 0.08, size: 6 },\n];\n\nexport default function XPBurst({ xp, visible = true }: Props) {\n  return (\n    <AnimatePresence>\n      {visible && (\n        <div className=\"fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 pointer-events-none\">\n          {/* Sparkle particles */}\n          {SPARKLES.map((s, i) => (\n            <motion.div\n              key={i}\n              className=\"absolute rounded-full\"\n              style={{ background: \"#FFA602\" }}\n              style={{\n                width: s.size,\n                height: s.size,\n                left: \"50%\",\n                top: \"50%\",\n              }}\n              initial={{ x: 0, y: 0, scale: 0, opacity: 1 }}\n              animate={{\n                x: s.x,\n                y: s.y,\n                scale: [0, 1.5, 0],\n                opacity: [1, 1, 0],\n              }}\n              transition={{ duration: 0.7, delay: s.delay, ease: \"easeOut\" }}\n            />\n          ))}\n\n          {/* Main XP badge */}\n          <motion.div\n            initial={{ scale: 0.3, opacity: 0, y: 0 }}\n            animate={{ scale: [0.3, 1.15, 1], opacity: 1, y: 0 }}\n            exit={{ scale: 1, opacity: 0, y: -80 }}\n            transition={{\n              scale: { duration: 0.45, ease: [0.34, 1.56, 0.64, 1] },\n              opacity: { duration: 0.3 },\n            }}\n          >\n            <div className=\"text-white font-bold font-display text-3xl px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-3\" style={{ background: \"linear-gradient(135deg, #FFA602, #EB670F)\", boxShadow: \"0 0 40px rgba(255, 166, 2, 0.4)\" }}>\n              <motion.span\n                animate={{ rotate: [0, -15, 15, -10, 10, 0] }}\n                transition={{ duration: 0.5, delay: 0.2 }}\n              >\n                ⚡\n              </motion.span>\n              <span>+{xp} XP</span>\n            </div>\n          </motion.div>\n        </div>\n      )}\n    </AnimatePresence>\n  );\n}\n","structuredPatch":[{"oldStart":26,"oldLines":8,"newStart":26,"newLines":8,"lines":["             <motion.div","               key={i}","               className=\"absolute rounded-full\"","-              style={{ background: \"#FFA602\" }}","               style={{","+                background: \"#FFA602\",","                 width: s.size,","                 height: s.size,","                 left: \"50%\","]}],"userModified":false,"replaceAll":false}}
